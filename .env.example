# Example environment variables for SI2 Mobile
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env file to version control

# API Configuration
API_BASE_URL=http://localhost:8000/api
API_VERSION=v1

# Debug Mode
DEBUG=false
LOG_LEVEL=info

# Firebase (if used)
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=

# Other
APP_NAME=SI2 Mobile
